# =====================================================
# Reusable Client Website Template - Environment Variables
# =====================================================
# Use Coolify environment variables for these values in production.
# Keep client business content, colours, offers, and long prompts in config/client.json
# and config/system_prompt.txt unless a simple override is needed.

# Server Configuration
PORT=3000
NODE_ENV=production

# Site Identity Overrides
SITE_URL=https://yourdomain.com
SITE_NAME="Client Business"
SITE_DESCRIPTION="A concise SEO-friendly description of the client business."
CLIENT_VERTICAL=general
SITE_TAGLINE="A short client tagline"
BUSINESS_ADDRESS=""
PUBLIC_PHONE=""
PUBLIC_EMAIL=hello@yourdomain.com
BOOKING_URL=https://calendly.com/client
CONTACT_URL=/contact/
RESPONSE_TIME="within one business day"
TIMEZONE=Australia/Sydney

# Email Configuration (Mailgun)
MAILGUN_API_KEY=your_mailgun_api_key_here
MAILGUN_DOMAIN=mg.yourdomain.com
MAILGUN_REGION=us
RECIPIENT_EMAIL=admin@yourdomain.com
EMAIL_TO=admin@yourdomain.com
EMAIL_FROM="Client Business <noreply@mg.yourdomain.com>"
REPLY_TO_EMAIL=hello@yourdomain.com

# PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/database

# Admin Dashboard
ADMIN_DASHBOARD_PASSWORD=change-this-password

# AI Chat Configuration (OpenRouter)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_MAX_TOKENS=1000
OPENROUTER_TEMPERATURE=0.7
OPENROUTER_USE_STREAMING=false

# Optional Web Search (Brave)
ENABLE_WEB_SEARCH=false
BRAVE_SEARCH_API_KEY=
MAX_SEARCHES_PER_SESSION=3
MAX_WEBPAGE_FETCHES_PER_SESSION=5
BRAVE_MONTHLY_QUOTA=2000
MAX_MONTHLY_SEARCHES=2000

# Feature Flags
ENABLE_CALLBACKS=true
ENABLE_DOWNLOAD_LEADS=true
ENABLE_BOOKINGS=true

# Optional Simple Chat Overrides
CHAT_TITLE="Chat with us"
CHAT_WELCOME="Hi, how can I help today?"
CHAT_INPUT_PLACEHOLDER="Ask a question..."
CHAT_SUGGESTED_QUESTIONS="How much does it cost?,Can I book a consultation?,Send me the guide"

# Optional Colour Overrides
COLOR_PRIMARY=#111111
COLOR_PRIMARY_LIGHT=#1a1a1a
COLOR_ACCENT=#9B8060
COLOR_ACCENT_HOVER=#7A6248
COLOR_COPPER=#B8A080
COLOR_BG_BODY=#FAFAFA
COLOR_BG_SURFACE=#ffffff
COLOR_TEXT_MAIN=#1A1A1A
COLOR_TEXT_SECONDARY=#727272
COLOR_TEXT_INVERSE=#F5F5F5
